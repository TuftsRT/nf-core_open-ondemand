#!/usr/bin/env bash

# Source this file before running nf2ood:
#
#   source ./nf2ood.env
#   ./nf2ood --input /path/to/pipelines --output /path/to/apps
#
# Generated apps will try to source this same file path at runtime. That only
# works if the path is also visible from the OOD host and compute nodes.
NF2OOD_ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export NF2OOD_ENV_FILE="${NF2OOD_ENV_DIR}/nf2ood.env"

# Open OnDemand app generation defaults.
export NF2OOD_CLUSTER="pax"
export NF2OOD_DEFAULT_DIRECTORY="/cluster/tufts"
export NF2OOD_PARTITION_YML="/etc/ood/config/apps/dashboard/batch_connect/partials/cpu_partition.yml"

# Generated job runtime defaults.
export NF2OOD_MODULE_NAME="nextflow"
export NF2OOD_CONTAINER_MODULE="singularity"
export NF2OOD_PIPELINE_ROOT="/cluster/tufts/apps/container/biocontainers/nf-core/pipelines"
export NF2OOD_SINGULARITY_CACHEDIR="/cluster/tufts/apps/container/biocontainers/nf-core/singularity-images"
export NF2OOD_SLURM_PROFILE="tufts"
